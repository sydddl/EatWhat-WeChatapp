/* Distance band selector: fixed four-column segments without overlap */
.radius-control {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
  width: 100%;
  box-sizing: border-box;
  margin-top: 14rpx;
  padding: 0;
  overflow: visible;
  border: 0;
  border-radius: 0;
  background: transparent;
}

.radius-option {
  display: flex;
  min-width: 0;
  width: 100%;
  max-width: 100%;
  height: 52rpx;
  box-sizing: border-box;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0 4rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: rgba(17, 17, 17, 0.055);
  color: rgba(17, 17, 17, 0.55);
  font-size: 20rpx;
  font-weight: 850;
  line-height: 52rpx;
  text-overflow: clip;
  white-space: nowrap;
}

