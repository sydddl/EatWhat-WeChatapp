page {
  background: #f4f4f2;
  color: #111111;
}

button::after {
  border: 0;
}

.nearby-page {
  min-height: 100vh;
}

.origin-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 22rpx 28rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e6e6e2;
}

.origin-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.origin-label {
  color: #747474;
  font-size: 22rpx;
}

.origin-name {
  max-width: 520rpx;
  overflow: hidden;
  color: #111111;
  font-size: 30rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.origin-action {
  flex: 0 0 auto;
  min-width: 104rpx;
  height: 58rpx;
  margin: 0;
  padding: 0 22rpx;
  border: 2rpx solid #111111;
  border-radius: 29rpx;
  background: #ffffff;
  color: #111111;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 54rpx;
}

.map-band {
  position: relative;
  width: 100%;
  height: 520rpx;
  background: #deded9;
}

.nearby-map {
  width: 100%;
  height: 100%;
}

.search-band {
  padding: 24rpx 28rpx 22rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e2e2de;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.search-input {
  min-width: 0;
  height: 72rpx;
  flex: 1;
  box-sizing: border-box;
  padding: 0 24rpx;
  border: 2rpx solid #cfcfca;
  border-radius: 36rpx;
  background: #f7f7f5;
  font-size: 28rpx;
}

.search-button {
  width: 132rpx;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 36rpx;
  background: #111111;
  color: #c6ff34;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.radius-control {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin-top: 18rpx;
  overflow: hidden;
  border: 2rpx solid #d6d6d0;
  border-radius: 8rpx;
}

.radius-option {
  min-width: 0;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: #ffffff;
  color: #666666;
  font-size: 23rpx;
  line-height: 58rpx;
}

.radius-option + .radius-option {
  border-left: 1rpx solid #d6d6d0;
}

.radius-option.is-active {
  background: #7f3aef;
  color: #ffffff;
  font-weight: 700;
}

.quota-notice {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 16rpx;
  color: #737373;
  font-size: 21rpx;
  line-height: 1.45;
}

.quota-notice-label {
  flex: 0 0 auto;
  padding: 2rpx 9rpx;
  border: 1rpx solid #bdbdb7;
  border-radius: 6rpx;
  color: #555555;
  font-size: 19rpx;
  font-weight: 700;
}

.quota-notice-text {
  min-width: 0;
  flex: 1;
}

.result-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 28rpx 16rpx;
}

.result-count {
  color: #333333;
  font-size: 25rpx;
  font-weight: 700;
}

.selection-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.text-action {
  height: 52rpx;
  margin: 0;
  padding: 0 12rpx;
  background: transparent;
  color: #7f3aef;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 52rpx;
}

.muted-action {
  color: #777777;
}

.place-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 0 20rpx;
}

.place-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx;
  border: 2rpx solid #e0e0db;
  border-radius: 12rpx;
  background: #ffffff;
}

.place-row.is-selected {
  border-color: #7f3aef;
  box-shadow: inset 8rpx 0 0 #c6ff34;
}

.selection-dot {
  display: flex;
  width: 38rpx;
  height: 38rpx;
  flex: 0 0 38rpx;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin-top: 2rpx;
  border: 2rpx solid #adada7;
  border-radius: 50%;
  background: #ffffff;
  color: #111111;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.is-selected .selection-dot {
  border-color: #c6ff34;
  background: #c6ff34;
}

.place-main {
  min-width: 0;
  flex: 1;
}

.place-title-line {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.place-title {
  min-width: 0;
  flex: 1;
  color: #111111;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.35;
}

.place-distance {
  flex: 0 0 auto;
  color: #7f3aef;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.5;
}

.place-address {
  display: block;
  margin-top: 7rpx;
  color: #777777;
  font-size: 24rpx;
  line-height: 1.45;
}

.place-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 13rpx;
}

.category-chip,
.map-chip {
  max-width: 100%;
  box-sizing: border-box;
  padding: 5rpx 14rpx;
  overflow: hidden;
  border-radius: 20rpx;
  font-size: 20rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-chip {
  background: #eee5ff;
  color: #5d20bf;
}

.map-chip {
  background: #e9f7bd;
  color: #334900;
}

.error-strip {
  margin: 0 20rpx 16rpx;
  padding: 16rpx 20rpx;
  border-left: 7rpx solid #7f3aef;
  background: #f0e8ff;
  color: #3e2366;
  font-size: 23rpx;
  line-height: 1.5;
}

.quota-error {
  border-left-color: #111111;
  background: #eeeeea;
  color: #111111;
}

.loading-state {
  padding: 80rpx 30rpx;
  color: #777777;
  font-size: 26rpx;
  text-align: center;
}

.origin-loading {
  min-height: 520rpx;
  box-sizing: border-box;
}

.load-more {
  width: 300rpx;
  height: 66rpx;
  margin: 26rpx auto 0;
  border: 2rpx solid #111111;
  border-radius: 33rpx;
  background: #ffffff;
  color: #111111;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 62rpx;
}

.footer-spacer {
  height: 164rpx;
}

.import-footer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.97);
  border-top: 1rpx solid #d8d8d2;
}

.selected-summary {
  display: flex;
  width: 110rpx;
  flex: 0 0 110rpx;
  flex-direction: column;
  align-items: center;
}

.selected-number {
  color: #7f3aef;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.selected-label {
  margin-top: 5rpx;
  color: #6f6f6f;
  font-size: 20rpx;
}

.import-button {
  min-width: 0;
  height: 78rpx;
  flex: 1;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 8rpx;
  background: #111111;
  color: #c6ff34;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 78rpx;
}

.import-button.is-disabled {
  background: #d6d6d1;
  color: #83837e;
}

.empty-state {
  display: flex;
  min-height: 560rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  padding: 50rpx;
  text-align: center;
}

.empty-title {
  color: #333333;
  font-size: 30rpx;
  font-weight: 700;
}

.button.primary {
  width: 320rpx;
  height: 76rpx;
  margin: 0;
  border-radius: 8rpx;
  background: #111111;
  color: #c6ff34;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 76rpx;
}

