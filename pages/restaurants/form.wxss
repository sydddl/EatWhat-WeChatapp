.restaurant-form-page {
  position: relative;
  padding-bottom: 132rpx;
  background: #fdfdfb;
}

.form-hero {
  position: relative;
  min-height: 236rpx;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 34rpx;
  background: #ffffff;
  border: 1rpx solid rgba(21, 21, 21, 0.07);
  box-shadow: 0 28rpx 72rpx rgba(21, 21, 21, 0.07);
}

.hero-copy,
.hero-badge {
  position: relative;
  z-index: 2;
}

.eyebrow {
  color: #7f3aef;
  font-size: 22rpx;
  font-weight: 900;
  margin-bottom: 10rpx;
}

.form-hero .subtitle {
  max-width: 450rpx;
  margin-top: 12rpx;
}

.hero-badge {
  position: absolute;
  right: 30rpx;
  bottom: 28rpx;
  width: 110rpx;
  height: 58rpx;
  border-radius: 12rpx;
  background: #151515;
  color: #c6ff34;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
}

.hero-mark {
  position: absolute;
  pointer-events: none;
}

.mark-a {
  right: -44rpx;
  top: -28rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 34% 24%, rgba(255,255,255,0.86), rgba(255,255,255,0) 28%), #7f3aef;
}

.mark-b {
  right: 100rpx;
  top: 88rpx;
  width: 72rpx;
  height: 148rpx;
  border-radius: 72rpx;
  background: linear-gradient(180deg, #151515 0%, #7f3aef 58%, #c6ff34 100%);
  opacity: 0.34;
  transform: rotate(14deg);
}

.parse-card,
.form-panel,
.enable-card,
.danger-card {
  box-sizing: border-box;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(21, 21, 21, 0.07);
  box-shadow: 0 16rpx 42rpx rgba(21, 21, 21, 0.05);
}

.parse-card {
  padding: 28rpx;
}

.form-panel {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.panel-title {
  color: #151515;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.panel-caption,
.field-hint,
.enable-copy {
  color: rgba(21, 21, 21, 0.54);
  font-size: 23rpx;
  line-height: 1.48;
}

.parse-button {
  flex: 0 0 auto;
  width: 116rpx;
  height: 58rpx;
  border-radius: 12rpx;
  background: #151515;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 58rpx;
}

.share-textarea {
  min-height: 178rpx;
  height: 178rpx;
  background: rgba(21, 21, 21, 0.035);
}

.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.required-dot {
  border-radius: 6rpx;
  background: rgba(127, 58, 239, 0.12);
  color: #7f3aef;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 34rpx;
  padding: 0 10rpx;
}

.split-row {
  display: flex;
  gap: 18rpx;
}

.split-field {
  flex: 1;
  min-width: 0;
}

.weight-field {
  width: 190rpx;
  flex: 0 0 190rpx;
}

.weight-input {
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
}

.tag-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 2rpx;
}

.tag-preview-chip {
  border-radius: 6rpx;
  background: rgba(21, 21, 21, 0.055);
  color: rgba(21, 21, 21, 0.72);
  font-size: 23rpx;
  font-weight: 750;
  line-height: 42rpx;
  padding: 0 14rpx;
}

.note-textarea {
  min-height: 178rpx;
  height: 178rpx;
}

.enable-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 26rpx 28rpx;
}

.enable-title {
  color: #151515;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.22;
}

.save-rail {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: 28rpx;
  z-index: 20;
  height: 92rpx;
  border-radius: 18rpx;
  background: #151515;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 92rpx;
  box-shadow: 0 18rpx 38rpx rgba(21, 21, 21, 0.18);
}
.danger-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 26rpx 28rpx;
  border-color: rgba(211, 48, 48, 0.18);
  background: rgba(211, 48, 48, 0.045);
}

.danger-title {
  color: #151515;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.22;
}

.danger-copy {
  color: rgba(21, 21, 21, 0.54);
  font-size: 23rpx;
  line-height: 1.48;
  margin-top: 6rpx;
}

.danger-button {
  flex: 0 0 auto;
  width: 124rpx;
  height: 62rpx;
  border-radius: 12rpx;
  background: #151515;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 62rpx;
}