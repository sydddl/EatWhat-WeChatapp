.members-page {
  padding-bottom: 76rpx;
  background: #fdfdfb;
}

.members-hero {
  position: relative;
  min-height: 220rpx;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 34rpx;
  background: #ffffff;
  border: 1rpx solid rgba(21, 21, 21, 0.07);
  box-shadow: 0 28rpx 72rpx rgba(21, 21, 21, 0.07);
}

.hero-copy,
.hero-count {
  position: relative;
  z-index: 2;
}

.eyebrow {
  color: #7f3aef;
  font-size: 22rpx;
  font-weight: 900;
  margin-bottom: 10rpx;
}

.hero-count {
  position: absolute;
  right: 30rpx;
  bottom: 28rpx;
  width: 112rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: #151515;
  color: #c6ff34;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 72rpx;
  text-align: center;
}

.hero-mark {
  position: absolute;
  pointer-events: none;
}

.mark-a {
  right: -44rpx;
  top: -28rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 34% 24%, rgba(255,255,255,0.86), rgba(255,255,255,0) 28%), #7f3aef;
}

.mark-b {
  right: 100rpx;
  top: 88rpx;
  width: 72rpx;
  height: 148rpx;
  border-radius: 72rpx;
  background: linear-gradient(180deg, #151515 0%, #7f3aef 58%, #c6ff34 100%);
  opacity: 0.34;
  transform: rotate(14deg);
}

.profile-card,
.group-setting-card {
  box-sizing: border-box;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(21, 21, 21, 0.07);
  box-shadow: 0 16rpx 42rpx rgba(21, 21, 21, 0.05);
}

.group-setting-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
}

.group-setting-copy {
  flex: 1;
  min-width: 0;
}

.group-setting-card .panel-title {
  margin-bottom: 8rpx;
}

.setting-value {
  overflow: hidden;
  color: #151515;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.4;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.setting-hint {
  margin-top: 6rpx;
  color: rgba(21, 21, 21, 0.5);
  font-size: 22rpx;
  line-height: 1.4;
}

.setting-button {
  flex: 0 0 auto;
  width: 112rpx;
  height: 60rpx;
  margin: 0;
  border-radius: 12rpx;
  background: #151515;
  color: #c6ff34;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 60rpx;
}

.panel-title {
  color: #151515;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
  margin-bottom: 18rpx;
}

.profile-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.profile-button {
  height: 76rpx;
  border-radius: 14rpx;
  background: #151515;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.nickname-row {
  display: flex;
  gap: 14rpx;
}

.nickname-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(21, 21, 21, 0.1);
  border-radius: 14rpx;
  background: #ffffff;
  color: #151515;
  font-size: 28rpx;
  padding: 0 18rpx;
}

.nickname-button {
  width: 128rpx;
  height: 76rpx;
  border-radius: 14rpx;
  background: #c6ff34;
  color: #151515;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.member-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.member-card {
  width: 154rpx;
  min-height: 188rpx;
  box-sizing: border-box;
  padding: 20rpx 12rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(21, 21, 21, 0.07);
  box-shadow: 0 14rpx 34rpx rgba(21, 21, 21, 0.045);
  text-align: center;
}

.member-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  margin: 0 auto;
}

.member-avatar.fallback {
  background: #151515;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 92rpx;
}

.member-name {
  margin-top: 14rpx;
  color: #151515;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
