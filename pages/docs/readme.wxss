.docs-page {
  padding-bottom: 76rpx;
  background: #fdfdfb;
}

.docs-hero {
  position: relative;
  min-height: 236rpx;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 34rpx;
  background: #ffffff;
  border: 1rpx solid rgba(21, 21, 21, 0.07);
  box-shadow: 0 28rpx 72rpx rgba(21, 21, 21, 0.07);
}

.hero-copy,
.hero-count {
  position: relative;
  z-index: 2;
}

.eyebrow {
  color: #7f3aef;
  font-size: 22rpx;
  font-weight: 900;
  margin-bottom: 10rpx;
}

.docs-hero .subtitle {
  max-width: 438rpx;
  margin-top: 12rpx;
}

.hero-count {
  position: absolute;
  right: 30rpx;
  bottom: 28rpx;
  width: 132rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: #151515;
  color: #c6ff34;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 64rpx;
  text-align: center;
}

.hero-mark {
  position: absolute;
  pointer-events: none;
}

.mark-a {
  right: -44rpx;
  top: -28rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 34% 24%, rgba(255,255,255,0.86), rgba(255,255,255,0) 28%), #7f3aef;
}

.mark-b {
  right: 100rpx;
  top: 88rpx;
  width: 72rpx;
  height: 148rpx;
  border-radius: 72rpx;
  background: linear-gradient(180deg, #151515 0%, #7f3aef 58%, #c6ff34 100%);
  opacity: 0.34;
  transform: rotate(14deg);
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-card {
  width: 326rpx;
  min-height: 116rpx;
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(21, 21, 21, 0.07);
  box-shadow: 0 14rpx 34rpx rgba(21, 21, 21, 0.045);
}

.quick-card.dark {
  background: #151515;
}

.quick-number {
  color: #7f3aef;
  font-size: 24rpx;
  font-weight: 900;
}

.dark .quick-number {
  color: #c6ff34;
}

.quick-label {
  margin-top: 10rpx;
  color: #151515;
  font-size: 28rpx;
  font-weight: 900;
}

.dark .quick-label {
  color: #ffffff;
}

.doc-card {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  box-sizing: border-box;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(21, 21, 21, 0.07);
  box-shadow: 0 16rpx 42rpx rgba(21, 21, 21, 0.05);
}

.doc-index {
  flex: 0 0 auto;
  width: 62rpx;
  height: 62rpx;
  border-radius: 12rpx;
  background: rgba(127, 58, 239, 0.12);
  color: #7f3aef;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 62rpx;
  text-align: center;
}

.doc-content {
  min-width: 0;
  flex: 1;
}

.heading {
  color: #151515;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.28;
}

.body {
  margin-top: 10rpx;
  color: rgba(21, 21, 21, 0.64);
  font-size: 27rpx;
  line-height: 1.68;
}

.tag-row {
  margin-top: 14rpx;
}

.doc-chip {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  border-radius: 6rpx;
  background: rgba(21, 21, 21, 0.055);
  color: rgba(21, 21, 21, 0.72);
  font-size: 22rpx;
  font-weight: 750;
  padding: 0 12rpx;
  margin: 8rpx 8rpx 0 0;
}

.formula-line {
  box-sizing: border-box;
  width: 100%;
  overflow-x: auto;
  border: 1rpx solid rgba(21, 21, 21, 0.08);
  border-radius: 12rpx;
  background: rgba(21, 21, 21, 0.035);
  color: #151515;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  font-size: 23rpx;
  line-height: 1.55;
  padding: 16rpx 18rpx;
  white-space: nowrap;
  margin-top: 14rpx;
}

.formula-line + .formula-line {
  margin-top: 12rpx;
}