.group-location-page {
  padding-bottom: 72rpx;
}

.location-hero {
  padding: 10rpx 4rpx 4rpx;
}

.eyebrow {
  margin-bottom: 10rpx;
  color: #7f3aef;
  font-size: 22rpx;
  font-weight: 900;
}

.location-panel {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  box-sizing: border-box;
  padding: 28rpx;
  border: 1rpx solid rgba(21, 21, 21, 0.08);
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 54rpx rgba(21, 21, 21, 0.06);
}

.location-summary {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 112rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(127, 58, 239, 0.07);
}

.location-pin {
  flex: 0 0 52rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #151515;
  color: #c6ff34;
  font-size: 20rpx;
  line-height: 52rpx;
  text-align: center;
}

.location-copy {
  flex: 1;
  min-width: 0;
}

.location-name {
  color: #151515;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.3;
}

.location-address {
  margin-top: 6rpx;
  color: rgba(21, 21, 21, 0.55);
  font-size: 24rpx;
  line-height: 1.4;
}

.location-open {
  flex: 0 0 auto;
  color: #7f3aef;
  font-size: 23rpx;
  font-weight: 850;
}

.location-empty {
  padding: 48rpx 24rpx;
  border: 2rpx dashed rgba(21, 21, 21, 0.12);
  border-radius: 18rpx;
  text-align: center;
}

.empty-mark {
  width: 58rpx;
  height: 58rpx;
  margin: 0 auto 16rpx;
  border-radius: 50%;
  background: #151515;
  color: #c6ff34;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 54rpx;
}

.empty-title {
  color: #151515;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-copy {
  margin-top: 8rpx;
  color: rgba(21, 21, 21, 0.52);
  font-size: 24rpx;
}

.clear-button {
  height: 58rpx;
  background: transparent;
  color: rgba(21, 21, 21, 0.46);
  font-size: 23rpx;
  line-height: 58rpx;
}
