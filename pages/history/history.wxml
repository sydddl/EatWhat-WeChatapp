<view class="page history-page">
  <view class="section history-hero">
    <view class="hero-orbit orbit-a"></view>
    <view class="hero-orbit orbit-b"></view>
    <view class="hero-content">
      <view class="eyebrow">MONTHLY LOG</view>
      <view class="title">抽签月历</view>
      <view class="subtitle">查看这个月抽了多少次、哪家店出现最多、哪几天最常决定吃饭。</view>
    </view>
    <view class="hero-total">
      <view class="total-number">{{total}}</view>
      <view class="total-label">本月</view>
    </view>
  </view>

  <view class="section month-bar">
    <button class="month-button" bindtap="prevMonth">‹</button>
    <view class="month-center">
      <view class="month-label">{{monthLabel}}</view>
      <view class="month-subtitle">按月统计</view>
    </view>
    <button class="month-button" bindtap="nextMonth">›</button>
  </view>

  <view wx:if="{{loading}}" class="empty">正在加载...</view>
  <block wx:else>
    <view class="section stats-grid">
      <view class="stat-card primary-stat">
        <view class="stat-number">{{total}}</view>
        <view class="stat-copy">本月抽签</view>
      </view>
      <view class="stat-card accent-stat">
        <view class="stat-number">{{topRestaurants.length}}</view>
        <view class="stat-copy">上榜餐厅</view>
      </view>
    </view>

    <view class="section panel calendar-panel">
      <view class="panel-head">
        <view>
          <view class="panel-title">日历热力</view>
          <view class="panel-caption">点击日期查看当天吃了什么</view>
        </view>
        <view class="legend-row"><text></text><text></text><text></text><text></text></view>
      </view>
      <view class="week-row"><text>日</text><text>一</text><text>二</text><text>三</text><text>四</text><text>五</text><text>六</text></view>
      <view class="calendar-grid">
        <view wx:for="{{calendarDays}}" wx:key="key" class="day-cell heat-{{item.intensity}} {{item.day === selectedDay ? 'is-selected' : ''}}" data-day="{{item.day}}" bindtap="selectCalendarDay">
          <view class="day-number">{{item.day}}</view>
          <view wx:if="{{item.count}}" class="day-count">{{item.count}}</view>
        </view>
      </view>
      <view wx:if="{{selectedDay}}" class="selected-day-panel">
        <view class="selected-day-head">
          <view class="selected-day-title">{{selectedDayTitle}}</view>
          <view class="selected-day-count">{{selectedDraws.length}} 次</view>
        </view>
        <view wx:if="{{selectedDraws.length === 0}}" class="muted selected-empty">这天还没有确认记录。</view>
        <view wx:for="{{selectedDraws}}" wx:key="_id" class="selected-draw-row">
          <view>
            <view class="selected-draw-name">{{item.restaurantSnapshot.name}}</view>
            <view class="muted selected-draw-address">{{item.restaurantSnapshot.address || '未填写地址'}}</view>
          </view>
          <view class="time-chip">{{item.createdText}}</view>
        </view>
      </view>
    </view>

    <view class="section panel chart-panel">
      <view class="panel-head">
        <view>
          <view class="panel-title">餐厅次数排行</view>
          <view class="panel-caption">统计本月抽中的餐厅频次</view>
        </view>
      </view>
      <view wx:if="{{topRestaurants.length === 0}}" class="muted empty-copy">这个月还没有抽签记录。</view>
      <view wx:for="{{topRestaurants}}" wx:key="name" class="rank-row">
        <view class="rank-head"><text>{{index + 1}}. {{item.name}}</text><text>{{item.count}} 次</text></view>
        <view class="rank-track"><view class="rank-fill" style="width: {{item.percent}}%;"></view></view>
      </view>
    </view>

    <view class="section record-head">
      <view class="panel-title">本月记录</view>
      <view class="panel-caption">最近确认的抽签结果在上方</view>
    </view>
    <view wx:if="{{draws.length === 0}}" class="empty">这个月还没有抽签记录。</view>
    <view wx:for="{{draws}}" wx:key="_id" class="section panel record-card">
      <view class="record-top">
        <view class="name">{{item.restaurantSnapshot.name}}</view>
        <view class="time-chip">{{item.createdText}}</view>
      </view>
      <view class="muted address">{{item.restaurantSnapshot.address || '未填写地址'}}</view>
      <view class="meta"><text class="chip">候选 {{item.candidateCount}} 家</text><text wx:if="{{item.filters.tag}}" class="chip">#{{item.filters.tag}}</text><text wx:if="{{item.filters.priceRange}}" class="chip">{{item.filters.priceRange}}</text><text wx:if="{{item.filters.locationText}}" class="chip">{{item.filters.locationText}}</text></view>
    </view>
  </block>
</view>